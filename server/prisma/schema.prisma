generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ตารางที่ 3-1 สมาชิก (members)
model User {
  id         Int      @id @default(autoincrement())
  firstname  String   @db.VarChar(50)
  lastname   String   @db.VarChar(50)
  email      String   @unique @db.VarChar(100)
  password   String   @db.VarChar(100) // เพิ่มขนาดรองรับการ Hash
  tel        String?  @db.VarChar(20)
  address    String?  @db.Text
  role       String   @default("user") // เปลี่ยน Enum เป็น String เพื่อความง่าย
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  orders     Order[]

  @@map("members") // ชื่อตารางในฐานข้อมูล
}

// ตารางที่ 3-2 ข้อมูลร้าน (ShopInfo)
model ShopInfo {
  shopId     Int      @id @default(autoincrement()) @map("shop_id")
  shopName   String   @db.VarChar(100) @map("shop_name")
  address    String?  @db.Text @map("Address")
  phone      String?  @db.VarChar(10)
  logo       String?  @db.VarChar(255)
  openTime   String?  @map("openTime") // หรือ DateTime แบบ Time
  closeTime  String?  @map("closeTime") // หรือ DateTime แบบ Time
  isOpen     Boolean  @default(true) @map("is_open")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("ShopInfo")
}

// ตารางที่ 3-3 หมวดหมู่อาหาร (categories)
model Category {
  categoryId   Int       @id @default(autoincrement()) @map("category_id")
  categoryName String    @db.VarChar(50) @map("categoryName")
  createdAt    DateTime  @default(now()) @map("created_at")

  products     Product[]

  @@map("categories")
}

// 🟢 ตารางที่ 3-4 เมนูอาหาร (products) - ตรงตามเอกสาร 100%
model Product {
  productId     Int      @id @default(autoincrement()) @map("product_id")
  categoryId    Int?     @map("category_id")
  title         String   @db.VarChar(150)
  description   String?  @db.Text
  price         Decimal  @db.Decimal(10, 2)
  image         String?  @db.VarChar(255)
  isRecommended Boolean  @default(false) @map("is_recommended") // 🟢 เมนูแนะนำ
  isAvailable   Boolean  @default(true) @map("is_available")   // 🟢 สถานะเปิด/ปิดการขาย
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // 💡 เพิ่มเติมสำหรับทำ "เมนูยอดนิยม" (ไม่มีในเอกสาร แต่จำเป็นต้องมีเพื่อนับยอด)
  soldCount     Int      @default(0) @map("sold_count")

  category      Category?   @relation(fields: [categoryId], references: [categoryId])
  orderItems    OrderItem[]

  @@map("products")
}

// ตารางที่ 3-5 คำสั่งซื้อ (orders)
model Order {
  ordersId      Int       @id @default(autoincrement()) @map("orders_id")
  userId        Int?      @map("user_id")
  orderType     String    @db.VarChar(15) @map("order_type")
  paymentMethod String    @db.VarChar(15) @map("payment_method")
  status        String    @db.VarChar(15)
  totalPrice    Decimal   @db.Decimal(10, 2) @map("total_price")
  note          String?   @db.Text
  orderDate     DateTime  @default(now()) @map("order_date")
  rejectReason  String?   @db.Text @map("reject_reason")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User?     @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payments      Payment[]

  @@map("orders")
}

// ตารางที่ 3-6 ข้อมูลรายละเอียดคำสั่งซื้อ (order_items)
model OrderItem {
  itemId      Int      @id @default(autoincrement()) @map("item_id")
  ordersId    Int      @map("orders_id")
  productId   Int      @map("product_id")
  unitPrice   Decimal  @db.Decimal(10, 2) @map("unit_price")
  quantity    Int
  note        String?  @db.Text

  order       Order    @relation(fields: [ordersId], references: [ordersId])
  product     Product  @relation(fields: [productId], references: [productId])

  @@map("order_items")
}

// ตารางที่ 3-7 การชำระเงิน (payments)
model Payment {
  paymentId     Int       @id @default(autoincrement()) @map("payment_id")
  ordersId      Int       @map("orders_id")
  paymentMethod String    @db.VarChar(20) @map("payment_method")
  amount        Decimal   @db.Decimal(10, 2)
  slipImage     String?   @db.VarChar(255) @map("slip_image")
  paymentStatus String    @db.VarChar(30) @map("payment_status")
  verifiedAt    DateTime? @map("verified_at")
  rejectReason  String?   @db.Text @map("reject_reason")

  order         Order     @relation(fields: [ordersId], references: [ordersId])

  @@map("payments")
}